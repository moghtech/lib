{
  "name": "mogh_ui",
  "version": "0.7.4",
  "description": "Common UI components and styling used across Mogh apps.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./index.scss": "./dist/index.scss",
    "./theme.scss": "./dist/theme.scss"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly && cd src && find . -name '*.scss' -exec cp --parents {} ../dist \\;",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@mantine/core": "^9.4.1",
    "@mantine/form": "^9.4.1",
    "@mantine/hooks": "^9.4.1",
    "@mantine/notifications": "^9.4.1",
    "@monaco-editor/react": "^4.7.0",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-query": "^5.101.2",
    "lucide-react": "^1.22.0",
    "mogh_auth_client": "^1.7.0",
    "monaco-editor": "^0.56.0",
    "monaco-yaml": "^5.5.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@mantine/core": "^9.4.1",
    "@mantine/form": "^9.4.1",
    "@mantine/hooks": "^9.4.1",
    "@mantine/notifications": "^9.4.1",
    "@monaco-editor/react": "^4.7.0",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-query": "^5.101.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "lucide-react": "^1.22.0",
    "mogh_auth_client": "^1.7.0",
    "monaco-editor": "^0.56.0",
    "monaco-yaml": "^5.5.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "tsup": "^8.5.1",
    "typescript": "^7.0.2"
  }
}